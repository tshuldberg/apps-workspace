{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CanonicalTask",
  "type": "object",
  "required": [
    "title",
    "description",
    "priority",
    "status",
    "source_system",
    "source_reference"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "minLength": 5
    },
    "project_id": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "description": "Email or PM user ID."
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "status": {
      "type": "string",
      "enum": ["backlog", "todo", "in_progress", "blocked", "done"]
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "dependency_task_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "source_system": {
      "type": "string",
      "enum": [
        "gmail",
        "outlook",
        "pm_tool",
        "manual",
        "apple_reminders",
        "messages",
        "superwhisper",
        "calendar"
      ]
    },
    "source_reference": {
      "type": "string",
      "description": "Thread ID, message ID, or external ticket ID."
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "value"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "email_id",
              "calendar_event_id",
              "task_id",
              "note",
              "message_id",
              "reminder_id",
              "transcript_id"
            ]
          },
          "value": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
