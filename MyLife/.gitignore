# The broad ios/ and android/ rules above target Expo-generated prebuild dirs.
# The owned @mylife/meerkat-native-transport package keeps its AUTHORED Swift and
# Kotlin sources under ios/ and android/; those must be tracked so a dev build can
# compile them (Plan 42 WP-42C). Un-ignore that package's native source trees.
!/packages/meerkat-native-transport/ios/
!/packages/meerkat-native-transport/ios/**
!/packages/meerkat-native-transport/android/
!/packages/meerkat-native-transport/android/**
# Same rule for the other owned native packages (Plan 41 WP-41F iCloud module,
# Plan 25 call-native module): authored sources must be tracked.
!/packages/meerkat-icloud-storage/ios/
!/packages/meerkat-icloud-storage/ios/**
!/packages/meerkat-call-native/ios/
!/packages/meerkat-call-native/ios/**
!/packages/meerkat-call-native/android/
!/packages/meerkat-call-native/android/**
coverage/
